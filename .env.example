# ─── Public-facing ───────────────────────────────────────────
NEXT_PUBLIC_BROWSER_VNC_URL=/vnc/vnc.html
NEXT_PUBLIC_APP_NAME=Hack A Ton 2026

# ─── Database (optional, reuses VPS Supabase) ────────────────
